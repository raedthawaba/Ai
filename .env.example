# ══════════════════════════════════════════════════════════════════════════════
# Hajeen AI Platform — Environment Variables
# انسخ هذا الملف إلى .env وعدّل القيم
# cp .env.example .env
# ══════════════════════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_PASSWORD=hajeen_pass_CHANGE_ME_in_production
DATABASE_URL=postgresql+asyncpg://hajeen:hajeen_pass_CHANGE_ME_in_production@postgres:5432/hajeen_db

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=redis_pass_CHANGE_ME_in_production
REDIS_URL=redis://:redis_pass_CHANGE_ME_in_production@redis:6379/0
REDIS_CACHE_URL=redis://:redis_pass_CHANGE_ME_in_production@redis:6379/1
REDIS_QUEUE_URL=redis://:redis_pass_CHANGE_ME_in_production@redis:6379/2

# ── JWT Security ──────────────────────────────────────────────────────────────
# openssl rand -hex 64
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_hex_64
JWT_TTL_SECONDS=3600
PASSWORD_SALT=CHANGE_ME_random_salt_string

# ── Admin Account ─────────────────────────────────────────────────────────────
ADMIN_PASSWORD=HajeenAdmin2024!_CHANGE_ME

# ── LLM Configuration ─────────────────────────────────────────────────────────
DEFAULT_LLM_PROVIDER=ollama
DEFAULT_MODEL=mistral:7b
OLLAMA_BASE_URL=http://ollama:11434

# ── Fine-tuned Model (اختياري) ────────────────────────────────────────────────
FINETUNED_MODEL_PATH=/app/models/hajeen_mistral_finetuned
FINETUNED_MODEL_NAME=hajeen-mistral-7b-v1
USE_FINETUNED_MODEL=false

# ── HuggingFace (للتحميل فقط) ─────────────────────────────────────────────────
# HF_TOKEN=hf_your_token_here
HF_HOME=/app/.cache/huggingface
BASE_MODEL_NAME=mistralai/Mistral-7B-Instruct-v0.2

# ── Monitoring ────────────────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=grafana_pass_CHANGE_ME

# ── Domain & SSL ──────────────────────────────────────────────────────────────
DOMAIN=yourdomain.com

# ── Application ───────────────────────────────────────────────────────────────
ENVIRONMENT=production
PORT=8000
LOG_LEVEL=info
DB_ECHO=false
ENABLE_RATE_LIMITING=true
ENABLE_AUTH=true

# ── Celery ────────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://:redis_pass_CHANGE_ME_in_production@redis:6379/3
CELERY_RESULT_BACKEND=redis://:redis_pass_CHANGE_ME_in_production@redis:6379/4
